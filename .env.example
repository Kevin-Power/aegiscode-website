# AegisCode website / license server environment template.
# Copy to .env.local for local development, or configure the same names in Vercel.
# Never commit real secrets.

# Public site origin used for redirects, checkout callbacks, and generated links.
NEXT_PUBLIC_SITE_URL=https://aegiscode.yilutek.com
# SITE_URL=https://aegiscode.yilutek.com

# Durable storage for license records, rate limits, and audit logs.
# Both values are required together. Vercel KV / Upstash provides these.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Optional; not used by server write paths.
KV_REST_API_READ_ONLY_TOKEN=

# Admin API and /admin pages.
ADMIN_TOKEN=

# RS256 license signing and validation.
# Store PEMs as single-line values with literal \n escapes.
LICENSE_SIGNING_PRIVATE_KEY=
LICENSE_PUBLIC_KEY=

# Optional one-time bootstrap into KV.
LICENSE_REGISTRY_JSON=

# Customer and sales email delivery. Use either Resend or SMTP.
RESEND_API_KEY=
RESEND_FROM=AegisCode <noreply@aegiscode.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AegisCode <noreply@aegiscode.com>
SALES_NOTIFY_EMAIL=sales@aegiscode.com

# Error reporting.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Self-service checkout is intentionally paused unless explicitly enabled.
SELF_SERVICE_CHECKOUT_ENABLED=0
NEXT_PUBLIC_SELF_SERVICE_CHECKOUT_ENABLED=0
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PROFESSIONAL=

# Emergency override only. Leave disabled in production until KV is configured.
ALLOW_EPHEMERAL_TRIAL_ISSUANCE=0

# HMAC secret used to sign /api/resources/download short-lived URLs.
# If unset, the route falls back to ADMIN_TOKEN. Set explicitly when you
# want to rotate download links without rotating the admin token.
DOWNLOAD_SIGNING_SECRET=
