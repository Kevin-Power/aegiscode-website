# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# license server local state (dev only — production uses LICENSE_REGISTRY_JSON or KV)
/data/licenses.json
/data/audit-log.json

# Policy (since the puppeteer HTML→PDF flow landed): the three marketing
# PDFs under private/downloads/ and public/downloads/ ARE committed to
# git. Vercel bundles private/downloads/ into the
# /api/resources/file/[assetId] function via next.config.ts
# outputFileTracingIncludes, and public/downloads/ ships through the CDN.
# Regenerate them locally with `npm run regenerate-pdfs` (see
# docs/PDF_REGENERATION.md) and commit the diff.

# Puppeteer downloads its bundled Chromium into ~/.cache/puppeteer (or
# %LOCALAPPDATA%/puppeteer on Windows) — outside the repo by default.
# Belt-and-braces ignores in case a future puppeteer release ever caches
# inside node_modules:
node_modules/puppeteer-core-cache/
node_modules/.puppeteer-cache/
